include         acetaminophen.params
# ----------------------------------------------------------------------
# Coefficients for Acetaminophen (CGenFF/CHARMM in LAMMPS)
# This file maps CHARMM/CGenFF parameters to the numeric type IDs
# that exist in *your* .data file.
#
# You only need to fill in the small "FILL THESE IN" block below
# using the ID->type tables printed at the top of your .data file.
# ----------------------------------------------------------------------

# ============================
# 0) FILL THESE IN (IDs only)
# ============================

# --- Atom type IDs (self LJ parameters applied to id,id) ---
# Set each variable to the numeric atom-type ID that your .data
# header shows for the given CGenFF atom type.
# Example: if the .data header says " 1 : CG2O1", put: variable AT_CG2O1 equal 1

# ---------- Atom type IDs ----------
variable AT_CG2O1   equal 1
variable AT_CG2R61  equal 2
variable AT_CG331   equal 3
variable AT_HGA3    equal 4
variable AT_HGP1    equal 5
variable AT_HGR61   equal 6
variable AT_NG2S1   equal 7
variable AT_OG2D1   equal 8
variable AT_OG311   equal 9

# ---------- Bond type IDs ----------
variable BT_CG2O1_CG331   equal 1
variable BT_CG2O1_NG2S1   equal 2
variable BT_CG2O1_OG2D1   equal 3
variable BT_CG2R61_CG2R61 equal 4
variable BT_CG2R61_HGR61  equal 5
variable BT_CG2R61_NG2S1  equal 6
variable BT_CG2R61_OG311  equal 7
variable BT_CG331_HGA3    equal 8
variable BT_NG2S1_HGP1    equal 9
variable BT_OG311_HGP1    equal 10

# ---------- Angle type IDs ----------
# (ends can be swapped; the central atom stays in the middle)
variable ATY_CG2O1_CG331_HGA3        equal 1
variable ATY_CG2R61_CG2R61_CG2R61    equal 2
variable ATY_CG2R61_CG2R61_HGR61     equal 3
variable ATY_CG2R61_CG2R61_NG2S1     equal 4
variable ATY_CG2R61_CG2R61_OG311     equal 5
variable ATY_CG2O1_NG2S1_CG2R61      equal 6
variable ATY_CG2R61_NG2S1_HGP1       equal 7
variable ATY_CG2R61_OG311_HGP1       equal 8
variable ATY_HGA3_CG331_HGA3         equal 9
variable ATY_CG2O1_NG2S1_HGP1        equal 10
variable ATY_CG331_CG2O1_NG2S1       equal 11
variable ATY_NG2S1_CG2O1_OG2D1       equal 12
variable ATY_CG331_CG2O1_OG2D1       equal 13

# ---------- Dihedral type IDs ----------
# (reversal of the 4 atoms is equivalent; mapping numbers come from your header)
variable DTY_CG2R61_CG2R61_CG2R61_CG2R61  equal 1
variable DTY_CG2R61_CG2R61_CG2R61_HGR61   equal 2
variable DTY_CG2R61_CG2R61_CG2R61_NG2S1   equal 3
variable DTY_CG2R61_CG2R61_NG2S1_CG2O1    equal 4
variable DTY_CG2R61_CG2R61_NG2S1_HGP1     equal 5
variable DTY_CG331_CG2O1_NG2S1_CG2R61     equal 6
variable DTY_OG2D1_CG2O1_NG2S1_CG2R61     equal 7
variable DTY_CG331_CG2O1_NG2S1_HGP1       equal 8
variable DTY_OG2D1_CG2O1_NG2S1_HGP1       equal 9
variable DTY_CG2R61_CG2R61_OG311_HGP1     equal 10
variable DTY_HGR61_CG2R61_CG2R61_CG2R61   equal 11
variable DTY_HGR61_CG2R61_CG2R61_NG2S1    equal 13
variable DTY_NG2S1_CG2R61_CG2R61_CG2R61   equal 15
variable DTY_HGR61_CG2R61_CG2R61_HGR61    equal 12
variable DTY_NG2S1_CG2R61_CG2R61_HGR61    equal 16
variable DTY_NG2S1_CG2O1_CG331_HGA3       equal 14
variable DTY_OG2D1_CG2O1_CG331_HGA3       equal 17
variable DTY_CG2R61_CG2R61_CG2R61_OG311   equal 18
variable DTY_OG311_CG2R61_CG2R61_HGR61    equal 19

# ---------- Improper type IDs ----------
variable ITY_CG2O1_CG331_NG2S1_OG2D1  equal 1


# =================================================
# 1) PAIR (NONBONDED) — lj/charmm/coul/long params
#    We provide (epsilon, sigma).  sigma = (2*Rmin/2) / 2^(1/6)
#    Values below are computed from your NONBONDED lines.
# =================================================

# CG2O1: eps=0.1100, Rmin/2=2.0000  -> sigma ≈ 3.5657
pair_coeff ${AT_CG2O1}  ${AT_CG2O1}   0.1100   3.5657   # CG2O1
pair_coeff 1  ${AT_CG2O1}   0.1100   3.5657   
pair_coeff 1  1   0.1100   3.5657   

# CG2R61: eps=0.0700, Rmin/2=1.9924 -> sigma ≈ 3.5500
pair_coeff ${AT_CG2R61} ${AT_CG2R61}  0.0700   3.5500   # CG2R61
pair_coeff 2 ${AT_CG2R61}  0.0700   3.5500   
pair_coeff 2 2  0.0700   3.5500   

# CG331: eps=0.0780, Rmin/2=2.0500  -> sigma ≈ 3.6529
pair_coeff ${AT_CG331}  ${AT_CG331}   0.0780   3.6529   # CG331
pair_coeff 3  ${AT_CG331}   0.0780   3.6529   
pair_coeff 3  3   0.0780   3.6529   

# HGA3: eps=0.0240, Rmin/2=1.3400   -> sigma ≈ 2.3870
pair_coeff ${AT_HGA3}   ${AT_HGA3}    0.0240   2.3870   # HGA3 (methyl H)
pair_coeff 4   ${AT_HGA3}    0.0240   2.3870   
pair_coeff 4   4    0.0240   2.3870   

# HGP1: eps=0.0460, Rmin/2=0.2245   -> sigma ≈ 0.4002
pair_coeff ${AT_HGP1}   ${AT_HGP1}    0.0460   0.4002   # HGP1 (polar H)
pair_coeff 5   ${AT_HGP1}    0.0460   0.4002   
pair_coeff 5   5    0.0460   0.4002   

# HGR61: eps=0.0300, Rmin/2=1.3582  -> sigma ≈ 2.4200
pair_coeff ${AT_HGR61}  ${AT_HGR61}   0.0300   2.4200   # HGR61 (aryl H)
pair_coeff 6  ${AT_HGR61}   0.0300   2.4200   
pair_coeff 6  6   0.0300   2.4200   

# NG2S1: eps=0.2000, Rmin/2=1.8500  -> sigma ≈ 3.2950
pair_coeff ${AT_NG2S1}  ${AT_NG2S1}   0.2000   3.2950   # NG2S1 (amide N)
pair_coeff 7  ${AT_NG2S1}   0.2000   3.2950   
pair_coeff 7  7   0.2000   3.2950   

# OG2D1: eps=0.1200, Rmin/2=1.7000  -> sigma ≈ 3.0280
pair_coeff ${AT_OG2D1}  ${AT_OG2D1}   0.1200   3.0280   # OG2D1 (carbonyl O)
pair_coeff 8  ${AT_OG2D1}   0.1200   3.0280   
pair_coeff 8  8   0.1200   3.0280   

# OG311: eps=0.1921, Rmin/2=1.7650  -> sigma ≈ 3.1470
pair_coeff ${AT_OG311}  ${AT_OG311}   0.1921   3.1470   # OG311 (phenolic O)
pair_coeff 9  ${AT_OG311}   0.1921   3.1470   
pair_coeff 9  9   0.1921   3.1470   


# ==========================================
# 2) BONDS — bond_style charmm (K  r0)
# ==========================================
bond_coeff ${BT_CG2O1_CG331}     250.00   1.4900   # CG2O1 - CG331
bond_coeff 1     250.00   1.4900   
bond_coeff ${BT_CG2O1_NG2S1}     370.00   1.3450   # CG2O1 - NG2S1
bond_coeff 2     370.00   1.3450   
bond_coeff ${BT_CG2O1_OG2D1}     620.00   1.2300   # CG2O1 - OG2D1
bond_coeff 3     620.00   1.2300   
bond_coeff ${BT_CG2R61_CG2R61}   305.00   1.3750   # CG2R61 - CG2R61
bond_coeff 4   305.00   1.3750   
bond_coeff ${BT_CG2R61_HGR61}    340.00   1.0800   # CG2R61 - HGR61
bond_coeff 5    340.00   1.0800   
bond_coeff ${BT_CG2R61_NG2S1}    305.00   1.4140   # CG2R61 - NG2S1
bond_coeff 6    305.00   1.4140   
bond_coeff ${BT_CG2R61_OG311}    334.30   1.4110   # CG2R61 - OG311
bond_coeff 7    334.30   1.4110   
bond_coeff ${BT_CG331_HGA3}      322.00   1.1110   # CG331  - HGA3
bond_coeff 8      322.00   1.1110   
bond_coeff ${BT_NG2S1_HGP1}      440.00   0.9970   # NG2S1  - HGP1
bond_coeff 9      440.00   0.9970   
bond_coeff ${BT_OG311_HGP1}      545.00   0.9600   # OG311  - HGP1
bond_coeff 10      545.00   0.9600   


# ===============================================================
# 3) ANGLES — angle_style charmm (Ktheta  theta0  Kub  r_ub)
# (If Kub/r_ub are omitted in PRM, use 0.0 0.0)
# ===============================================================
angle_coeff ${ATY_CG2O1_CG331_HGA3}      33.00   109.50   30.00   2.16300
angle_coeff 1      33.00   109.50   30.00   2.16300
angle_coeff ${ATY_CG2O1_NG2S1_HGP1}      34.00   123.00    0.00   0.00000
angle_coeff 10      34.00   123.00    0.00   0.00000
angle_coeff ${ATY_CG2R61_CG2R61_CG2R61}  40.00   120.00   35.00   2.41620
angle_coeff 2  40.00   120.00   35.00   2.41620
angle_coeff ${ATY_CG2R61_CG2R61_HGR61}   30.00   120.00   22.00   2.15250
angle_coeff 3   30.00   120.00   22.00   2.15250
angle_coeff ${ATY_CG2R61_CG2R61_NG2S1}   40.00   120.00   35.00   2.41620
angle_coeff 4   40.00   120.00   35.00   2.41620
angle_coeff ${ATY_CG2R61_CG2R61_OG311}   45.20   120.00    0.00   0.00000
angle_coeff 5   45.20   120.00    0.00   0.00000
angle_coeff ${ATY_CG2O1_NG2S1_CG2R61}    50.00   120.00    0.00   0.00000
angle_coeff 6    50.00   120.00    0.00   0.00000
angle_coeff ${ATY_CG2R61_NG2S1_HGP1}     34.00   117.00    0.00   0.00000
angle_coeff 7     34.00   117.00    0.00   0.00000
angle_coeff ${ATY_CG2R61_OG311_HGP1}     65.00   108.00    0.00   0.00000
angle_coeff 8     65.00   108.00    0.00   0.00000
angle_coeff ${ATY_CG331_CG2O1_NG2S1}     80.00   116.50    0.00   0.00000
angle_coeff 11     80.00   116.50    0.00   0.00000
angle_coeff ${ATY_CG331_CG2O1_OG2D1}     80.00   121.00    0.00   0.00000
angle_coeff 13     80.00   121.00    0.00   0.00000
angle_coeff ${ATY_HGA3_CG331_HGA3}       35.50   108.40    5.40   1.80200
angle_coeff 9       35.50   108.40    5.40   1.80200
angle_coeff ${ATY_NG2S1_CG2O1_OG2D1}     80.00   122.50    0.00   0.00000
angle_coeff 12     80.00   122.50    0.00   0.00000


# ========================================================================================
# 4) DIHEDRALS — dihedral_style charmm
# One line can contain up to 4 Fourier terms: (K1 n1 d1   K2 n2 d2   K3 n3 d3   K4 n4 d4)
# If a dihedral appears multiple times in PRM (different n), we combine them on one line.
# ========================================================================================

# 1  CG2R61-CG2R61-CG2R61-CG2R61
dihedral_coeff ${DTY_CG2R61_CG2R61_CG2R61_CG2R61}   3.1000  2  180  0.5   # 6-ring backbone → 0.5
dihedral_coeff 1   3.1000  2  180  0.5   

# 2  CG2R61-CG2R61-CG2R61-HGR61
dihedral_coeff ${DTY_CG2R61_CG2R61_CG2R61_HGR61}    4.2000  2  180  1.0
dihedral_coeff 2    4.2000  2  180  1.0

# 3  CG2R61-CG2R61-CG2R61-NG2S1
dihedral_coeff ${DTY_CG2R61_CG2R61_CG2R61_NG2S1}    3.1000  2  180  1.0
dihedral_coeff 3    3.1000  2  180  1.0

# 4  CG2R61-CG2R61-NG2S1-CG2O1
dihedral_coeff ${DTY_CG2R61_CG2R61_NG2S1_CG2O1}     1.2000  2  180  1.0
dihedral_coeff 4     1.2000  2  180  1.0

# 5  CG2R61-CG2R61-NG2S1-HGP1
dihedral_coeff ${DTY_CG2R61_CG2R61_NG2S1_HGP1}      0.5000  2  180  1.0
dihedral_coeff 5      0.5000  2  180  1.0

# 6  CG331-CG2O1-NG2S1-CG2R61  (two terms)
dihedral_coeff ${DTY_CG331_CG2O1_NG2S1_CG2R61}      1.6000  1    0  1.0
dihedral_coeff 6      1.6000  1    0  1.0
dihedral_coeff ${DTY_CG331_CG2O1_NG2S1_CG2R61}      2.5000  2  180  1.0
dihedral_coeff 6      2.5000  2  180  1.0

# 7  OG2D1-CG2O1-NG2S1-CG2R61
dihedral_coeff ${DTY_OG2D1_CG2O1_NG2S1_CG2R61}      2.5000  2  180  1.0
dihedral_coeff 7      2.5000  2  180  1.0

# 8  CG331-CG2O1-NG2S1-HGP1
dihedral_coeff ${DTY_CG331_CG2O1_NG2S1_HGP1}        2.5000  2  180  1.0
dihedral_coeff 8        2.5000  2  180  1.0

# 9  OG2D1-CG2O1-NG2S1-HGP1
dihedral_coeff ${DTY_OG2D1_CG2O1_NG2S1_HGP1}        2.5000  2  180  1.0
dihedral_coeff 9        2.5000  2  180  1.0

# 10 CG2R61-CG2R61-OG311-HGP1
dihedral_coeff ${DTY_CG2R61_CG2R61_OG311_HGP1}      0.9900  2  180  1.0
dihedral_coeff 10      0.9900  2  180  1.0

# 11 HGR61-CG2R61-CG2R61-CG2R61  (reverse of type 2)
dihedral_coeff ${DTY_HGR61_CG2R61_CG2R61_CG2R61}    4.2000  2  180  1.0
dihedral_coeff 11    4.2000  2  180  1.0

# 12 HGR61-CG2R61-CG2R61-HGR61
dihedral_coeff ${DTY_HGR61_CG2R61_CG2R61_HGR61}     2.4000  2  180  1.0
dihedral_coeff 12     2.4000  2  180  1.0

# 13 HGR61-CG2R61-CG2R61-NG2S1  (reverse of type 16)
dihedral_coeff ${DTY_HGR61_CG2R61_CG2R61_NG2S1}     2.4000  2  180  1.0
dihedral_coeff 13     2.4000  2  180  1.0

# 14 NG2S1-CG2O1-CG331-HGA3    (“no torsion potential”)
dihedral_coeff ${DTY_NG2S1_CG2O1_CG331_HGA3}        0.0000  3    0  1.0
dihedral_coeff 14        0.0000  3    0  1.0

# 15 NG2S1-CG2R61-CG2R61-CG2R61 (reverse of type 3)
dihedral_coeff ${DTY_NG2S1_CG2R61_CG2R61_CG2R61}    3.1000  2  180  1.0
dihedral_coeff 15    3.1000  2  180  1.0

# 16 NG2S1-CG2R61-CG2R61-HGR61
dihedral_coeff ${DTY_NG2S1_CG2R61_CG2R61_HGR61}     2.4000  2  180  1.0
dihedral_coeff 16     2.4000  2  180  1.0

# 17 OG2D1-CG2O1-CG331-HGA3    (“no torsion potential”, 180° phase)
dihedral_coeff ${DTY_OG2D1_CG2O1_CG331_HGA3}        0.0000  3  180  1.0
dihedral_coeff 17        0.0000  3  180  1.0

# 18 CG2R61-CG2R61-CG2R61-OG311
dihedral_coeff ${DTY_CG2R61_CG2R61_CG2R61_OG311}    3.1000  2  180  1.0
dihedral_coeff 18    3.1000  2  180  1.0

# 19 OG311-CG2R61-CG2R61-HGR61
dihedral_coeff ${DTY_OG311_CG2R61_CG2R61_HGR61}     2.4000  2  180  1.0
dihedral_coeff 19     2.4000  2  180  1.0


# ===============================================
# 5) IMPROPERS — improper_style harmonic (K  chi0)
# Planarity around the amide (sp2) is enforced here.
# ===============================================
# PRM entry: "CG2O1  CG331  NG2S1  OG2D1    120.00  0     0.00"
# For LAMMPS harmonic: use K=120.00, chi0=0.00 degrees.
improper_coeff ${ITY_CG2O1_CG331_NG2S1_OG2D1}   120.00   0.00
improper_coeff 1   120.00   0.00

# ----------------------------------------------------------------------
# END
# ----------------------------------------------------------------------

kspace_style    pppm 1.0e-5

# --------------------------------------------------------------------
# SECTION 4 — DEFINE ORIGINAL CRYSTAL CELL GEOMETRY (INNER BOX)
# --------------------------------------------------------------------

variable        inner_xlo equal 0.0
variable        inner_xhi equal 35.47110000     # original xhi
variable        inner_ylo equal 0.0
variable        inner_yhi equal 29.58840000     # original yhi
variable        inner_zlo equal 0.0
variable        inner_zhi equal 34.30520000     # original zhi

# Crystal volume (Å^3) from ORIGINAL inner box
variable        Vcryst0 equal (v_inner_xhi-v_inner_xlo)*(v_inner_yhi-v_inner_ylo)*(v_inner_zhi-v_inner_zlo)

# Current (big) simulation box volume
variable        Vbox0 equal vol

# --------------------------------------------------------------------
# SECTION 5 — TIP3P-CHARMM WATER TYPES AND PARAMETERS
# --------------------------------------------------------------------

mass            10 15.9994      # TIP3P O
mass            11 1.0080       # TIP3P H

pair_coeff      10 10  0.1521  3.1507
pair_coeff      11 11  0.0460  0.4

bond_coeff      11  450.0   0.9572
angle_coeff     14  55.0  104.52  0.0  0.0

# Water density & constants
variable        rho_target equal 1.0
variable        Mw         equal 18.01528
variable        NA         equal 6.02214076e23

# --------------------------------------------------------------------
# SECTION 6 — NEIGHBOR LIST
# --------------------------------------------------------------------

neighbor        2.0 bin
neigh_modify    every 10 delay 0 check yes

# --------------------------------------------------------------------
# SECTION 7 — MONITORING AND OUTPUT (for log, including minimize)
# --------------------------------------------------------------------

thermo          2500
thermo_style    custom step temp press pe etotal vol density lx ly lz
thermo_modify   flush yes

# --------------------------------------------------------------------
# SECTION 8 — REMOVE NET MOMENTUM
# --------------------------------------------------------------------

fix             mom all momentum 1000 linear 1 1 1 angular

# --------------------------------------------------------------------
# SECTION 9 — COMPUTE WATER VOLUME AND NUMBER OF WATER MOLECULES
# --------------------------------------------------------------------

variable        Vwater      equal ${Vbox0}-${Vcryst0}
variable        Vwater      equal 811867.304529974-${Vcryst0}
variable        Vwater      equal 811867.304529974-36004.4427388272
variable        nwater_real equal ${rho_target}*${NA}*${Vwater}/(${Mw}*1.0e24)
variable        nwater_real equal 1*${NA}*${Vwater}/(${Mw}*1.0e24)
variable        nwater_real equal 1*6.02214076e+23*${Vwater}/(${Mw}*1.0e24)
variable        nwater_real equal 1*6.02214076e+23*775862.861791147/(${Mw}*1.0e24)
variable        nwater_real equal 1*6.02214076e+23*775862.861791147/(18.01528*1.0e24)
variable        nwater      equal floor(v_nwater_real+0.5)

print "Original crystal volume (A^3): ${Vcryst0}"
Original crystal volume (A^3): 36004.4427388272
print "Current box volume (A^3):      ${Vbox0}"
Current box volume (A^3):      811867.304529974
print "Water region volume (A^3):     ${Vwater}"
Water region volume (A^3):     775862.861791147
print "Target water molecules:        ${nwater}"
Target water molecules:        25936

# --------------------------------------------------------------------
# SECTION 10 — DEFINE REGIONS AND INSERT WATER
# --------------------------------------------------------------------

group           crystal type 1 2 3 4 5 6 7 8 9
3840 atoms in group crystal

region          outer block INF INF INF INF INF INF units box

region          inner_in block ${inner_xlo} ${inner_xhi} ${inner_ylo} ${inner_yhi} ${inner_zlo} ${inner_zhi} units box side in
region          inner_in block 0 ${inner_xhi} ${inner_ylo} ${inner_yhi} ${inner_zlo} ${inner_zhi} units box side in
region          inner_in block 0 35.4711 ${inner_ylo} ${inner_yhi} ${inner_zlo} ${inner_zhi} units box side in
region          inner_in block 0 35.4711 0 ${inner_yhi} ${inner_zlo} ${inner_zhi} units box side in
region          inner_in block 0 35.4711 0 29.5884 ${inner_zlo} ${inner_zhi} units box side in
region          inner_in block 0 35.4711 0 29.5884 0 ${inner_zhi} units box side in
region          inner_in block 0 35.4711 0 29.5884 0 34.3052 units box side in

region          inner_out block ${inner_xlo} ${inner_xhi} ${inner_ylo} ${inner_yhi} ${inner_zlo} ${inner_zhi} units box side out
region          inner_out block 0 ${inner_xhi} ${inner_ylo} ${inner_yhi} ${inner_zlo} ${inner_zhi} units box side out
region          inner_out block 0 35.4711 ${inner_ylo} ${inner_yhi} ${inner_zlo} ${inner_zhi} units box side out
